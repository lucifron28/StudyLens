direction: down

# -----------------
# Style Definitions
# -----------------
classes: {
  android_layer: {
    style: {
      fill: "#3DDC84"
      stroke: "#2E8B57"
      font-color: "black"
      border-radius: 5
    }
  }
  backend_app: {
    style: {
      fill: "#2F7D68"
      stroke: "#1D5D4B"
      font-color: "white"
      border-radius: 5
    }
  }
  db_node: {
    style: {
      fill: "#336791"
      stroke: "#214B6B"
      font-color: "white"
    }
  }
  ai_node: {
    style: {
      fill: "#F4B400"
      stroke: "#D9A000"
    }
  }
}

# -----------------
# Android Client
# -----------------
"Android Application (StudyLens)": {
  icon: "https://api.iconify.design/simple-icons:android.svg"
  style.fill: "#E8F5E9"
  
  "UI & Feature Layer": {
    class: android_layer
    "Jetpack Compose (Screens)": { icon: "https://api.iconify.design/mdi:palette.svg" }
    "ViewModels (State & Actions)": { icon: "https://api.iconify.design/mdi:brain.svg" }
  }

  "Core & Data Layer": {
    class: android_layer
    "Repositories (DTO Mapping)": { icon: "https://api.iconify.design/mdi:package.svg" }
    "Room Cache (Subjects, Modules, Scans)": { icon: "https://api.iconify.design/mdi:database.svg" }
    "DataStore (JWT and Theme)": { icon: "https://api.iconify.design/mdi:database-outline.svg" }
    "Retrofit & AuthInterceptor": { icon: "https://api.iconify.design/mdi:api.svg" }
  }

  "Hardware & OCR": {
    class: android_layer
    "CameraX": { icon: "https://api.iconify.design/mdi:camera.svg" }
    "Image Cropper": { icon: "https://api.iconify.design/mdi:crop.svg" }
    "ML Kit OCR": { icon: "https://api.iconify.design/mdi:text-recognition.svg" }
  }
  
  "File Management": {
    class: android_layer
    "Native PdfRenderer": { icon: "https://api.iconify.design/mdi:file-pdf-box.svg" }
    "Local File Cache": { icon: "https://api.iconify.design/mdi:folder-multiple.svg" }
  }

  "Profile": {
    class: android_layer
    "Account Details and Avatar": { icon: "https://api.iconify.design/mdi:account-circle.svg" }
  }

  # Android Internal Routing
  "UI & Feature Layer"."Jetpack Compose (Screens)" -> "UI & Feature Layer"."ViewModels (State & Actions)"
  "UI & Feature Layer"."ViewModels (State & Actions)" -> "Core & Data Layer"."Repositories (DTO Mapping)"
  "Core & Data Layer"."Repositories (DTO Mapping)" <-> "Core & Data Layer"."Room Cache (Subjects, Modules, Scans)": "Read cache or refresh"
  "Core & Data Layer"."Repositories (DTO Mapping)" -> "Core & Data Layer"."Retrofit & AuthInterceptor"
  "Core & Data Layer"."DataStore (JWT and Theme)" -> "Core & Data Layer"."Retrofit & AuthInterceptor": "Injects Token"
  "UI & Feature Layer"."Jetpack Compose (Screens)" -> "Profile"."Account Details and Avatar"
  "Profile"."Account Details and Avatar" -> "Core & Data Layer"."Repositories (DTO Mapping)"
  
  "Hardware & OCR"."CameraX" -> "Hardware & OCR"."Image Cropper"
  "Hardware & OCR"."Image Cropper" -> "Hardware & OCR"."ML Kit OCR"
  "Hardware & OCR"."ML Kit OCR" -> "Core & Data Layer"."Repositories (DTO Mapping)": "Text and optional image"
  "Core & Data Layer"."Repositories (DTO Mapping)" -> "File Management"."Local File Cache": "Downloads"
  "File Management"."Local File Cache" -> "File Management"."Native PdfRenderer"
}

# -----------------
# Backend Platform
# -----------------
"Backend Platform": {
  direction: right

  "Dockerized Backend Server": {
    icon: "https://api.iconify.design/simple-icons:docker.svg"
    style.fill: "#E0F2F1"

    "Django REST Framework": {
      icon: "https://api.iconify.design/simple-icons:django.svg"
      class: backend_app

      "accounts (Auth, JWT)"
      "learning (Subjects, Modules)"
      "studytools (Quizzes, Flashcards)"
      "ai_services (Tutor, Prompts)"
    }

    "Document Extraction Pipeline": {
      icon: "https://api.iconify.design/mdi:cogs.svg"
      class: backend_app
      "PyMuPDF (PDF)": { icon: "https://api.iconify.design/mdi:file-pdf-box.svg" }
      "python-docx (Word)": { icon: "https://api.iconify.design/mdi:file-word-box.svg" }
      "python-pptx (PowerPoint)": { icon: "https://api.iconify.design/mdi:file-powerpoint-box.svg" }
      "Office to PDF Conversion (Future)": { icon: "https://api.iconify.design/mdi:clock-outline.svg" }
    }

    "Django REST Framework"."learning (Subjects, Modules)" -> "Document Extraction Pipeline": "Extracts uploaded text"
    "Django REST Framework"."ai_services (Tutor, Prompts)" -> "Django REST Framework"."learning (Subjects, Modules)": "Reads Context"
  }

  "PostgreSQL": {
    icon: "https://api.iconify.design/simple-icons:postgresql.svg"
    class: db_node
    shape: cylinder
    label: "PostgreSQL\n(Student-Owned Data)"
  }

  "Media Volume": {
    icon: "https://api.iconify.design/mdi:harddisk.svg"
    shape: cylinder
    style.fill: "#795548"
    style.font-color: "white"
    label: "Media Storage\n(PDFs, Board Scans)"
  }

  "AI Providers": {
    icon: "https://api.iconify.design/mdi:robot-outline.svg"
    style.fill: "#FFF8E1"

    "DeepSeek": {
      icon: "https://api.iconify.design/mdi:cloud-outline.svg"
      class: ai_node
      shape: cloud
      label: "DeepSeek\n(Optional cloud provider)"
    }
    "Ollama": {
      icon: "https://api.iconify.design/mdi:server-network.svg"
      class: ai_node
      shape: queue
      label: "Local Ollama\n(qwen3:4b-instruct)"
    }
  }
}

# =================
# Global Connections
# =================

# Mobile to Backend
"Android Application (StudyLens)"."Core & Data Layer"."Retrofit & AuthInterceptor" -> "Backend Platform"."Dockerized Backend Server"."Django REST Framework": "HTTPS REST, JSON, multipart"

# Backend to DB/Storage
"Backend Platform"."Dockerized Backend Server"."Django REST Framework" <-> "Backend Platform"."PostgreSQL": "Read/Write (psycopg)"
"Backend Platform"."Dockerized Backend Server"."Django REST Framework" -> "Backend Platform"."Media Volume": "Uploads & Static"

# Backend to AI (Enforcing the security rule: Mobile never touches AI directly)
"Backend Platform"."Dockerized Backend Server"."Django REST Framework"."ai_services (Tutor, Prompts)" -> "Backend Platform"."AI Providers"."DeepSeek": "When configured"
"Backend Platform"."Dockerized Backend Server"."Django REST Framework"."ai_services (Tutor, Prompts)" -> "Backend Platform"."AI Providers"."Ollama": "Local default"

